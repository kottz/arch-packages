#!/usr/bin/env bash

set -euo pipefail

# shellcheck source=scripts/common.sh
source "$(dirname -- "${BASH_SOURCE[0]}")/common.sh"

for package in $(selected_packages "$@"); do
  ensure_source_repo "$package"
  repo=$(source_dir "$package")
  branch=${PACKAGE_BRANCH[$package]}

  git -C "$repo" fetch origin "$branch" --tags
  git -C "$repo" fetch upstream --tags

  latest=$(latest_upstream_tag "$package")
  [[ -n $latest ]] || die "$package has no matching upstream tag"

  git -C "$repo" switch "$branch"
  git -C "$repo" rebase "$latest"
  run_source_tests "$package"
done
