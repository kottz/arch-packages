#!/usr/bin/env bash

set -euo pipefail

ROOT=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)
CREDSTORE_DIR=${KOTTZ_CREDSTORE_DIR:-/etc/credstore.encrypted}
CRED_PREFIX=${KOTTZ_CREDENTIAL_PREFIX:-kottz.arch-packages}

usage() {
  cat <<USAGE
usage: ${0##*/} <command> [args...]

Run a command in a transient systemd unit with the arch-packages credentials.
USAGE
}

if [[ $# -eq 0 ]]; then
  usage >&2
  exit 2
fi

systemd-run \
  --wait \
  --collect \
  --property="WorkingDirectory=$ROOT" \
  --property="LoadCredentialEncrypted=telegram_bot_token:$CREDSTORE_DIR/$CRED_PREFIX.telegram_bot_token" \
  --property="LoadCredentialEncrypted=telegram_chat_id:$CREDSTORE_DIR/$CRED_PREFIX.telegram_chat_id" \
  --property="LoadCredentialEncrypted=openrouter_api_key:$CREDSTORE_DIR/$CRED_PREFIX.openrouter_api_key" \
  --property="LoadCredentialEncrypted=github_token:$CREDSTORE_DIR/$CRED_PREFIX.github_token" \
  "$@"
