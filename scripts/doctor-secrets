#!/usr/bin/env bash

set -euo pipefail

ROOT=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)

# shellcheck source=scripts/credentials
source "$ROOT/scripts/credentials"

usage() {
  cat <<USAGE
usage: ${0##*/}

Check required systemd credentials for kottz Arch package automation.
USAGE
}

while [[ $# -gt 0 ]]; do
  case $1 in
    -h|--help)
      usage
      exit 0
      ;;
    *)
      usage >&2
      exit 2
      ;;
  esac
  shift
done

status=0

require_credential() {
  local name=$1
  local path
  if path=$(credential_path "$name") && [[ -s $path ]]; then
    printf 'ok: %s credential is present\n' "$name"
  else
    printf 'fail: %s credential is missing or empty\n' "$name"
    status=1
  fi
}

require_credential telegram_bot_token
require_credential telegram_chat_id
require_credential openrouter_api_key

if [[ -n ${OPENCODE_MODEL:-} ]]; then
  printf 'ok: OPENCODE_MODEL is set to %s\n' "$OPENCODE_MODEL"
else
  printf 'ok: OPENCODE_MODEL using default openrouter/moonshotai/kimi-k2.7-code\n'
fi

if path=$(credential_path github_token) && [[ -s $path ]]; then
  printf 'ok: github_token credential is present\n'
else
  printf 'ok: github_token credential is empty or missing; assuming SSH deploy keys or SSH auth are used\n'
fi

exit "$status"
