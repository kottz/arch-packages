#!/usr/bin/env bash

credential_dir() {
  printf '%s\n' "${KOTTZ_CREDENTIALS_DIR:-${CREDENTIALS_DIRECTORY:-}}"
}

credential_path() {
  local name=$1
  local dir
  dir=$(credential_dir)
  [[ -n $dir && -r $dir/$name ]] || return 1
  printf '%s/%s\n' "$dir" "$name"
}

credential_value() {
  local name=$1
  local env_name=${2:-}

  if [[ -n $env_name && -n ${!env_name:-} ]]; then
    printf '%s' "${!env_name}"
    return 0
  fi

  local path
  path=$(credential_path "$name") || return 1
  cat "$path"
}

credential_required_path() {
  local name=$1
  local path
  path=$(credential_path "$name") || {
    printf 'error: missing required systemd credential: %s\n' "$name" >&2
    return 1
  }
  printf '%s\n' "$path"
}

credential_required_value() {
  local name=$1
  local env_name=${2:-}
  local value
  value=$(credential_value "$name" "$env_name") || {
    printf 'error: missing required systemd credential: %s\n' "$name" >&2
    return 1
  }
  [[ -n $value ]] || {
    printf 'error: required systemd credential is empty: %s\n' "$name" >&2
    return 1
  }
  printf '%s' "$value"
}
