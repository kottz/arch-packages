#!/usr/bin/env bash

set -euo pipefail

# shellcheck source=scripts/common.sh
source "$(dirname -- "${BASH_SOURCE[0]}")/common.sh"

for package in $(selected_packages "$@"); do
  ensure_source_repo "$package"
  repo=$(source_dir "$package")
  branch=${PACKAGE_BRANCH[$package]}
  remote_ref=refs/remotes/origin/$branch

  "$ROOT/scripts/git-with-credentials" git -C "$repo" fetch "${PACKAGE_FETCH_URL[$package]}" \
    "$branch:refs/remotes/origin/$branch" --tags
  "$ROOT/scripts/git-with-credentials" git -C "$repo" fetch upstream --tags

  latest=$(latest_upstream_tag "$package")
  current=$(git -C "$repo" rev-parse --short "$remote_ref")

  if [[ -z $latest ]]; then
    printf '%s: no upstream tags matching %s; current %s\n' \
      "$package" "${PACKAGE_TAG_MATCH[$package]}" "$current"
  elif git -C "$repo" merge-base --is-ancestor "$latest" "$remote_ref"; then
    printf '%s: origin/%s %s already contains latest upstream tag %s\n' \
      "$package" "$branch" "$current" "$latest"
  else
    printf '%s: origin/%s %s needs rebase onto upstream tag %s\n' \
      "$package" "$branch" "$current" "$latest"
  fi
done
