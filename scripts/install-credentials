#!/usr/bin/env bash

set -euo pipefail

ROOT=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)

SECRETS_FILE=${KOTTZ_SECRETS_FILE:-/srv/kottz/secrets/kottz-secrets/secrets/arch-packages.enc.yaml}
CREDSTORE_DIR=${KOTTZ_CREDSTORE_DIR:-/etc/credstore.encrypted}
CRED_PREFIX=${KOTTZ_CREDENTIAL_PREFIX:-kottz.arch-packages}

if [[ $EUID -ne 0 ]]; then
  printf 'error: run this script as root on the builder host\n' >&2
  exit 1
fi

command -v sops >/dev/null 2>&1 || {
  printf 'error: sops is required\n' >&2
  exit 1
}
command -v systemd-creds >/dev/null 2>&1 || {
  printf 'error: systemd-creds is required\n' >&2
  exit 1
}

[[ -f $SECRETS_FILE ]] || {
  printf 'error: missing SOPS secrets file: %s\n' "$SECRETS_FILE" >&2
  exit 1
}

if [[ ${SOPS_AGE_KEY_FILE:-} != "" && ! -r ${SOPS_AGE_KEY_FILE} ]]; then
  printf 'error: SOPS_AGE_KEY_FILE is not readable: %s\n' "$SOPS_AGE_KEY_FILE" >&2
  exit 1
fi

systemd-creds setup
install -d -m 0700 "$CREDSTORE_DIR"

tmpdir=$(mktemp -d)
trap 'rm -rf "$tmpdir"' EXIT

extract_secret() {
  local sops_path=$1
  local output=$2

  sops --decrypt --input-type yaml --output-type yaml \
    --extract "$sops_path" "$SECRETS_FILE" >"$output"
  chmod 0600 "$output"
}

install_credential() {
  local name=$1
  local sops_path=$2
  local required=${3:-required}
  local plain=$tmpdir/$name
  local target=$CREDSTORE_DIR/$CRED_PREFIX.$name

  extract_secret "$sops_path" "$plain"

  if [[ $required == required && ! -s $plain ]]; then
    printf 'error: required secret is empty: %s (%s)\n' "$name" "$sops_path" >&2
    exit 1
  fi

  systemd-creds encrypt --with-key=host --name="$name" "$plain" "$target"
  chmod 0600 "$target"
  printf 'installed credential: %s\n' "$target"
}

install_credential telegram_bot_token '["telegram"]["bot_token"]'
install_credential telegram_chat_id '["telegram"]["chat_id"]'
install_credential openrouter_api_key '["openrouter"]["api_key"]'
install_credential github_token '["github"]["token"]' optional

printf 'ok: installed systemd encrypted credentials from %s\n' "$SECRETS_FILE"
