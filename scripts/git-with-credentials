#!/usr/bin/env bash

set -euo pipefail

ROOT=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)

# shellcheck source=scripts/credentials
source "$ROOT/scripts/credentials"

token_file=$(credential_path github_token || true)

if [[ -n $token_file && -s $token_file ]]; then
  export GIT_TERMINAL_PROMPT=0
  export GIT_ASKPASS=$ROOT/scripts/github-askpass
  export KOTTZ_GITHUB_TOKEN_FILE=$token_file
fi

exec "$@"
